{
  "name": "UserAccount",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "description": "Unique username"
    },
    "email": {
      "type": "string",
      "description": "Email address (optional, used for login and premium)"
    },
    "password_hash": {
      "type": "string",
      "description": "Hashed password"
    },
    "login_method": {
      "type": "string",
      "enum": [
        "username",
        "email",
        "both"
      ],
      "default": "both",
      "description": "How the user can log in"
    },
    "last_login": {
      "type": "string",
      "format": "date-time",
      "description": "Last login timestamp"
    },
    "device_type": {
      "type": "string",
      "description": "mobile or desktop"
    },
    "os": {
      "type": "string",
      "description": "Operating system detected at login"
    },
    "browser": {
      "type": "string",
      "description": "Browser detected at login"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "admin"
      ],
      "default": "user",
      "description": "User role"
    },
    "is_premium": {
      "type": "boolean",
      "default": false,
      "description": "Premium subscription status"
    },
    "premium_since": {
      "type": "string",
      "format": "date-time",
      "description": "When premium was activated"
    },
    "premium_until": {
      "type": "string",
      "format": "date-time",
      "description": "Premium expiry date (null = lifetime)"
    },
    "map_settings": {
      "type": "object",
      "description": "Saved map preferences per user",
      "properties": {
        "active_base_layers": {
          "type": "object",
          "description": "Active base layers with opacity"
        },
        "active_layers": {
          "type": "object",
          "description": "Active overlay layers with opacity"
        },
        "favorite_layers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Favorite layer IDs"
        },
        "button_scale": {
          "type": "number",
          "description": "Mobile button scale"
        },
        "toolbar_hidden": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Hidden toolbar button IDs"
        },
        "toolbar_pos": {
          "type": "object",
          "description": "Desktop toolbar position {x, y}"
        },
        "theme": {
          "type": "object",
          "description": "UI theme colors"
        }
      }
    }
  },
  "required": [
    "username",
    "password_hash"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}